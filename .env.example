# Convex deployment URL — get from `npx convex dev` output, run in habittrackerweb/my-app
EXPO_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# Better Auth host — use the Convex .site URL (mobile talks to Convex directly).
# This is the SAME deployment as above, just the .site domain instead of .cloud.
EXPO_PUBLIC_AUTH_URL=https://<your-deployment>.convex.site
